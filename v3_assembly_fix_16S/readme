# Fix the 16S region of the merrill23 wRi assembly

## Attempt #2 — Direct insertion from Flye assembly (SUCCESSFUL)

Strategy:
- Identify the 16S in an independent Flye assembly of the same sample
- Determine the true extent of the missing region by mapping assembly flanks to the Flye contig
- Extract the entire missing region from the Flye assembly
- Insert it directly at the N gap position
- Polish with pilon using short reads
- Verify with blast

### Key findings
- The 16S was present at 100% identity in `contig_44` of the Flye assembly (coords 765419-766923, reverse complement)
- The missing region in the polished assembly was **144,486 bp** (contig_44:728866-873352), not just the 1520bp 16S
- Both flanks confirmed on **+ strand** by mapping left/right flanks to Flye contig_44
- Assembly left flank (before Ns) matches contig_44:728750-728866
- Assembly right flank (after Ns) matches contig_44:873250-873352
- Assembly wraps: very end of assembly matches contig_44:77250-77350; assembly start matches contig_44:77350+
```bash
mamba activate 16S_fix

# File paths
assembly="/private/groups/russelllab/jodie/Jacobs_et_al_2026_de_novo_wRi_merrill_23_assembly/ena_submission/20251218_Merrill23_wRi_wRi_M23.assembly.fasta"
short_reads="/private/groups/russelllab/jodie/Jacobs_et_al_2026_de_novo_wRi_merrill_23_assembly/data/short_reads/20251218_Merrill23_wRi.wri.trimmed.filtered.fastq.gz"
long_reads="/private/groups/russelllab/jodie/Jacobs_et_al_2026_de_novo_wRi_merrill_23_assembly/data/basecalled/merge/20251218_Merrill23_wRi.plus_bootcamp.wRiM23.fastq.gz"
flye_assembly="/private/groups/russelllab/jodie/Jacobs_et_al_2026_de_novo_wRi_merrill_23_assembly/data/flye/20251218_Merrill23_wRi/wRi_merged_bootcamp/assembly.fasta"


# Rotate circlator output so Ns are internal (TGS-GapCloser requires flanks on both sides)
# NOTE: Ns must be in the middle, not at start or end
python3 << 'EOF'
with open("circlator_output/06.fixstart.fasta") as f:
    header = f.readline().strip()
    seq = f.read().replace('\n', '')

n_len = 1520
real_seq = seq[n_len:]
mid = len(real_seq) // 2
rotated = real_seq[mid:] + 'N' * n_len + real_seq[:mid]

print(f"Original length: {len(seq)}")
print(f"Rotated length: {len(rotated)}")
print(f"N position in rotated: {rotated.find('N')}")

with open("rotated_for_gapclosing.fasta", "w") as f:
    f.write(header + "\n")
    for i in range(0, len(rotated), 60):
        f.write(rotated[i:i+60] + "\n")
print("Done: rotated_for_gapclosing.fasta")
EOF

# Verify Ns are internal
grep -v ">" rotated_for_gapclosing.fasta | tr -d '\n' | grep -ob 'N\+' | awk -F: '{print "start="$1, "length="length($2)}'

# Find 16S in the Flye assembly
blastn -query wRi_16S.fasta \
    -subject $flye_assembly \
    -outfmt 6 -evalue 1e-5 -perc_identity 75 \
    -out blast_16S_vs_flye.txt && cat blast_16S_vs_flye.txt
# Result: contig_44  100%  coords 766923-765419 (reverse complement)

# Extract 16S from Flye assembly (reverse complement with -i flag)
samtools faidx $flye_assembly contig_44:765419-766923 | samtools faidx - -i > wRi_16S_from_flye.fasta

# Confirm orientation by mapping assembly flanks to Flye assembly
# Extract 500bp flanks around the N gap
python3 -c "
with open('rotated_for_gapclosing.fasta') as f:
    f.readline()
    seq = f.read().replace('\n','')
left = seq[651015:651515]
right = seq[653035:653535]
with open('left_flank.fasta', 'w') as f:
    f.write('>left_flank\n' + left + '\n')
with open('right_flank.fasta', 'w') as f:
    f.write('>right_flank\n' + right + '\n')
"

minimap2 -ax asm5 $flye_assembly left_flank.fasta right_flank.fasta | \
    samtools view -F 4 | \
    awk '{print "query="$1, "ref="$3, "pos="$4, "end="$4+length($10), "strand=", ($2 % 32 >= 16) ? "-" : "+", "mapq="$5}'
# Result:
# left_flank  contig_44  pos=728366  end=728866  strand=+  mapq=60
# right_flank contig_44  pos=873352  end=873852  strand=+  mapq=60

# Confirmed: missing region is contig_44:728866-873352 (144,486 bp), + strand
# Extract full missing region from Flye assembly
samtools faidx $flye_assembly contig_44:728866-873352 > missing_region.fasta
grep -v ">" missing_region.fasta | tr -d '\n' | wc -c

# Insert missing region at N gap
python3 << 'EOF'
with open("rotated_for_gapclosing.fasta") as f:
    header = f.readline().strip()
    seq = f.read().replace('\n', '')

with open("missing_region.fasta") as f:
    f.readline()
    insert_seq = f.read().replace('\n', '')

# Find N gap
n_start = seq.find('N' * 100)
n_end = n_start
while n_end < len(seq) and seq[n_end] == 'N':
    n_end += 1

print(f"N gap: {n_start} - {n_end} (length {n_end - n_start})")
print(f"Insert length: {len(insert_seq)} bp")

new_seq = seq[:n_start] + insert_seq + seq[n_end:]

print(f"Original length: {len(seq)}")
print(f"New length: {len(new_seq)}")
print(f"Ns remaining: {new_seq.count('N')}")

with open("assembly_region_inserted.fasta", "w") as f:
    f.write(header + "\n")
    for i in range(0, len(new_seq), 60):
        f.write(new_seq[i:i+60] + "\n")
print("Done: assembly_region_inserted.fasta")
EOF

# Verify 16S is now present
blastn -query wRi_16S.fasta \
    -subject assembly_region_inserted.fasta \
    -outfmt 6 -evalue 1e-5 -perc_identity 75 | cat

# Polish inserted region with pilon using short reads
bwa index assembly_region_inserted.fasta
bwa mem -t 16 assembly_region_inserted.fasta $short_reads | samtools sort -o aligned_reads.bam
samtools index aligned_reads.bam
pilon --genome assembly_region_inserted.fasta --frags aligned_reads.bam --output pilon_polished --threads 16

# Final verification
blastn -query wRi_16S.fasta \
    -subject pilon_polished.fasta \
    -outfmt 6 -evalue 1e-5 -perc_identity 75 \
    -out blast_16S_vs_final.txt && cat blast_16S_vs_final.txt

# File paths
inserted_assembly="assembly_region_inserted.fasta"
insertion_start=651515   # where missing region was inserted
insertion_end=$((651515 + 144486))  # end of inserted region

# Index the assembly
samtools faidx $inserted_assembly
bwa index $inserted_assembly

# 1. Map long reads
minimap2 -ax map-ont \
    --secondary=no \
    -t 16 \
    $inserted_assembly \
    $long_reads | \
    samtools view -F 4 -b | \
    samtools sort -o long_reads_vs_inserted.bam
samtools index long_reads_vs_inserted.bam

# 2. Map short reads
bwa mem -t 16 $inserted_assembly $short_reads | \
    samtools view -F 4 -b | \
    samtools sort -o short_reads_vs_inserted.bam
samtools index short_reads_vs_inserted.bam

# 3. Overall coverage stats
samtools coverage long_reads_vs_inserted.bam
samtools coverage short_reads_vs_inserted.bam

insertion_start=651515
insertion_end=$((651515 + 144486))
echo "insertion_start=$insertion_start insertion_end=$insertion_end"

# 4. Check bridging long reads at left junction (reads spanning insertion_start +/- 5kb)
samtools view long_reads_vs_inserted.bam \
    "wRi_Merrill23_polished:$((insertion_start - 5000))-$((insertion_start + 5000))" | \
    awk -v junc=$insertion_start '{
        start=$4; end=$4+length($10);
        if (start < junc-1000 && end > junc+1000)
            print "BRIDGES_LEFT_JUNCTION\t"$1"\tstart="start"\tend="end"\tlen="length($10)
    }' | head -20

# 5. Check bridging long reads at right junction
samtools view long_reads_vs_inserted.bam \
    "wRi_Merrill23_polished:$((insertion_end - 5000))-$((insertion_end + 5000))" | \
    awk -v junc=$insertion_end '{
        start=$4; end=$4+length($10);
        if (start < junc-1000 && end > junc+1000)
            print "BRIDGES_RIGHT_JUNCTION\t"$1"\tstart="start"\tend="end"\tlen="length($10)
    }' | head -20

# 6. Short read coverage depth across whole assembly (for plotting)
samtools depth -a short_reads_vs_inserted.bam > short_read_depth.txt
samtools depth -a long_reads_vs_inserted.bam > long_read_depth.txt

wc -l short_read_depth.txt long_read_depth.txt
python3 << 'EOF'
import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
import numpy as np

insertion_start = 651515
insertion_end   = 651515 + 144486

# 16S position within inserted assembly
contig44_insert_start = 728866
assembly_16S_start = insertion_start + (765419 - contig44_insert_start)
assembly_16S_end   = insertion_start + (766923 - contig44_insert_start)
print(f"16S in assembly: {assembly_16S_start} - {assembly_16S_end}")

def load_depth(path, binsize=1000):
    pos, depth = [], []
    with open(path) as f:
        for line in f:
            _, p, d = line.strip().split()
            pos.append(int(p))
            depth.append(int(d))
    pos   = np.array(pos)
    depth = np.array(depth)
    bins  = np.arange(0, pos[-1], binsize)
    binned_depth = [depth[(pos >= b) & (pos < b + binsize)].mean() for b in bins]
    return bins, np.array(binned_depth)

def add_regions(ax, insertion_start, insertion_end, sixS_start, sixS_end):
    ax.axvspan(insertion_start/1e6, insertion_end/1e6,
               alpha=0.1, color='red', label='Inserted region (144kb)')
    ax.axvline(insertion_start/1e6, color='red', linestyle='--', linewidth=1, alpha=0.8)
    ax.axvline(insertion_end/1e6,   color='red', linestyle='--', linewidth=1, alpha=0.8)
    ax.axvspan(sixS_start/1e6, sixS_end/1e6,
               alpha=0.6, color='gold', label='16S rRNA')

fig, axes = plt.subplots(3, 1, figsize=(16, 12))

# Whole assembly - short reads
bins, depth = load_depth('short_read_depth.txt')
axes[0].fill_between(bins/1e6, depth, alpha=0.7, color='#2196F3')
add_regions(axes[0], insertion_start, insertion_end, assembly_16S_start, assembly_16S_end)
axes[0].set_ylabel('Mean depth')
axes[0].set_title('Short read coverage — whole assembly')
axes[0].set_xlabel('Position (Mb)')
axes[0].legend(fontsize=8)

# Whole assembly - long reads
bins, depth = load_depth('long_read_depth.txt')
axes[1].fill_between(bins/1e6, depth, alpha=0.7, color='#4CAF50')
add_regions(axes[1], insertion_start, insertion_end, assembly_16S_start, assembly_16S_end)
axes[1].set_ylabel('Mean depth')
axes[1].set_title('Long read coverage — whole assembly')
axes[1].set_xlabel('Position (Mb)')
axes[1].legend(fontsize=8)

# Zoomed - short reads around insertion +/- 50kb
zoom_start = max(0, insertion_start - 50000)
zoom_end   = insertion_end + 50000

with open('short_read_depth.txt') as f:
    data  = [line.strip().split() for line in f]
pos   = np.array([int(d[1]) for d in data])
depth = np.array([int(d[2]) for d in data])

mask = (pos >= zoom_start) & (pos <= zoom_end)
axes[2].fill_between(pos[mask]/1e6, depth[mask], alpha=0.7, color='#2196F3')
add_regions(axes[2], insertion_start, insertion_end, assembly_16S_start, assembly_16S_end)
axes[2].set_ylabel('Depth')
axes[2].set_title('Short read coverage — zoomed around insertion (+/- 50kb)')
axes[2].set_xlabel('Position (Mb)')
axes[2].legend(fontsize=8)

plt.tight_layout()
plt.savefig('coverage_verification.png', dpi=150, bbox_inches='tight')
print("Saved: coverage_verification.png")
EOF
```

