wRi_Merrill23_polished	$((insertion_start - padding))	$((insertion_start + padding))	left_junction
wRi_Merrill23_polished	$((insertion_end - padding))	$((insertion_end + padding))	right_junction
wRi_Merrill23_polished	$((assembly_16S_start - padding))	$((assembly_16S_end + padding))	16S_rRNA
wRi_Merrill23_polished	$((insertion_start - padding))	$((insertion_end + padding))	full_insertion
EOF

cat regions_of_interest.bed

# Generate IGV report - long reads
create_report \
    regions_of_interest.bed \
    --fasta assembly_region_inserted.fasta \
    --tracks long_reads_vs_inserted.bam short_reads_vs_inserted.bam \
    --output igv_report.html
```


## End 


## Attempt #1 — TGS-GapCloser (FAILED)

Strategy:
- Introduce N's at the beginning of the assembly where the 16S should be
- Rotate the assembly to start at the dnaA gene with circlator
- Fill N's with TGS-GapCloser using targeted long reads
- Polish with pilon using short reads
- Check the 16S region with blast

### Why it failed
- TGS-GapCloser `gap_total=0` because Ns were at position 0 (no upstream flank to anchor reads)
- After rotation fix, TGS-GapCloser found the gap but failed overlap check (`contig overlap check failed`)
- Root cause: the missing region is **144kb** (not just 1520bp) — only 1520 Ns were introduced but the true gap is much larger
- TGS-GapCloser cannot bridge a gap larger than the reads can span when flanking sequence is also missing

### Troubleshooting notes
- circlator has a `pkg_resources` bug on Python 3.13; use Python 3.12
- circlator `__init__.py` must be patched: replace `from pkg_resources import get_distribution` with `from importlib.metadata import version as get_distribution`
- SPAdes 4.x causes SIGILL on Emerald (AVX instruction incompatibility); use `spades=3.15.5`
- wMel 16S too divergent from wRi for read mapping; use wRi 16S from CP001391 (coords 1289969-1291473)
- Rotation script had a bug placing Ns at the end instead of the middle; fixed by splitting `real_seq` at midpoint and concatenating as `real_seq[mid:] + Ns + real_seq[:mid]`
- racon causes SIGILL on Emerald; use `--ne` flag to skip racon polishing
```bash
# Create conda environments with necessary tools
mamba create -n 16S_fix -c bioconda -c conda-forge tgsgapcloser pilon blast samtools bwa racon seqtk minimap2 entrez-direct
mamba create -n circlator_py312 python=3.12 -c bioconda -c conda-forge \
    bwa \
    prodigal \
    "samtools=1.3" \
    mummer \
    "spades=3.15.5" \
    setuptools

mamba activate circlator_py312
pip install circlator

# Patch circlator pkg_resources bug
INIT=$(find /private/groups/russelllab/jodie/miniforge3/envs/circlator_py312 -name "__init__.py" -path "*/circlator/*")
sed -i 's/from pkg_resources import get_distribution/from importlib.metadata import version as get_distribution/' $INIT

circlator progcheck

# Introduce N's at the beginning of the assembly (1520 Ns = length of wRi 16S)
awk 'NR==1{print} NR==2{for(i=1;i<=1520;i++)printf "N"; print $0} NR>2{print $0}' $assembly | fold -w 80 > assembly_with_Ns.fasta

# Rotate the assembly to start at the dnaA gene with circlator
mamba activate circlator_py312
circlator all --threads 16 assembly_with_Ns.fasta $short_reads circlator_output
mamba activate 16S_fix

# Fetch wRi 16S reference from NCBI for validation
# wRi 16S coords in CP001391: 1289969-1291473
efetch -db nuccore -id CP001391 -seq_start 1289969 -seq_stop 1291473 -format fasta > wRi_16S.fasta
```
